FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

# Install dependencies
RUN npm install --legacy-peer-deps && \
    npm cache clean --force

# Copy the entire app
COPY . .

# Set environment variables
ENV NODE_ENV=development
ENV PORT=3000
ENV PUBLIC_URL=/
ENV WATCHPACK_POLLING=true

EXPOSE 3000

# Start development server with hot reload
CMD ["npm", "run", "dev"] 